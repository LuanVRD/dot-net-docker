## Ignore Visual Studio temporary files, build results, and files generated by popular Visual Studio add-ons.
## Combined from https://github.com/github/gitignore/blob/main/VisualStudio.gitignore

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Mono auto generated files
mono_crash.*

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
x64/
x86/
[Aa]rm/
[Aa]rm64/
bld/
[Bb]in/
[Oo]bj/
[Log]/
[Intermediate]/

# Visual Studio 2015/2017 cache directory
.vs/
# Generated file conflicts
*_i.c
*_p.c
*_h.h
*.ilk
*.meta
*.obj
*.iobj
*.pch
*.pdb
*.ipdb
*.pgc
*.pgd
*.rsp
*.sbr
*.tlb
*.tli
*.tlh
*.tmp
*.tmp_proj
*_wpftmp.csproj
*.log
*.vspscc
*.vsscc
*.webinfo
*.xml
*.scc

# Visual Studio Product Installation Metadata
*.msi
*.msix
*.msu
*.msp

# Rider
.idea/
*.sln.iml

# VS Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# Local Database Files
*.db
*.db-journal
*.sqlite
*.sqlite3

# Docker/Docker-compose
.dockerignore
!docker-compose.yml
!src/TaskManager.API/Dockerfile

# OS files
.DS_Store
Thumbs.db

# User Secrets
/src/TaskManager.API/Properties/serviceDependencies.json
/src/TaskManager.API/Properties/serviceDependencies.local.json
